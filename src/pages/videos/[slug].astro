---
import { getCollection } from 'astro:content';
import DefaultLayout from '../../layouts/DefaultLayout.astro';
import VideoPlayer from '../../components/VideoPlayer.vue';
import MdxContentEnhanced from '../../components/MdxContentEnhanced.vue';


export async function getStaticPaths() {
  const videos = await getCollection('videos');
  return videos.map(video => ({
    params: { slug: video.id },
    props: { video },
  }));
}

const { video } = Astro.props;
const { title, description, date, category, tags, videoFile, thumbnail, duration } = video.data;

// Récupération des vidéos liées (même catégorie ou tags communs)
const allVideos = await getCollection('videos');
const relatedVideos = allVideos
  .filter(v => 
    v.id !== video.id && 
    (v.data.category === category || v.data.tags.some(tag => tags.includes(tag)))
  )
  .slice(0, 3);

const formatDate = (date: Date) => {
  return new Date(date).toLocaleDateString('fr-FR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const formatDuration = (seconds: number) => {
  const hours = Math.floor(seconds / 3600);
  const minutes = Math.floor((seconds % 3600) / 60);
  const secs = seconds % 60;
  
  if (hours > 0) {
    return `${hours}h ${minutes}min ${secs}s`;
  }
  if (minutes > 0) {
    return `${minutes}min ${secs}s`;
  }
  return `${secs}s`;
};

const categoryLabels = {
  tutorial: '🎓 Tutoriel',
  presentation: '📊 Présentation',
  demo: '🚀 Démo',
  webinar: '💻 Webinar',
  vlog: '🎬 Vlog',
  interview: '🎙️ Interview',
  other: '📹 Autre',
};
---

<DefaultLayout 
  title={`${title} | Vidéothèque`}
  description={description}
>
  <div class="max-w-7xl mx-auto">
    <!-- Fil d'Ariane -->
    <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-8">
      <a href="/" class="hover:text-violet-600 dark:hover:text-violet-400 transition-colors">
        Accueil
      </a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <a href="/" class="hover:text-violet-600 dark:hover:text-violet-400 transition-colors">
        Vidéos
      </a>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <span class="text-gray-900 dark:text-white font-medium truncate">
        {title}
      </span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Colonne principale : Vidéo + Infos -->
      <div class="lg:col-span-2 space-y-6">
        <!-- Player vidéo -->
        <div class="bg-black rounded-2xl overflow-hidden shadow-2xl">
          <VideoPlayer 
            videoSrc={videoFile}
            thumbnail={thumbnail}
            title={title}
            client:load 
          />
        </div>

        <!-- Informations de la vidéo -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6 space-y-6">
          <!-- En-tête -->
          <div class="space-y-4">
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">
              {title}
            </h1>
            
            <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 dark:text-gray-400">
              <time datetime={date.toISOString()} class="flex items-center gap-1.5">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                {formatDate(date)}
              </time>
              
              {duration && (
                <span class="flex items-center gap-1.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  {formatDuration(duration)}
                </span>
              )}
              
              <span class="px-3 py-1 bg-violet-100 dark:bg-violet-900/50 text-violet-700 dark:text-violet-300 rounded-full text-xs font-medium">
                {categoryLabels[category]}
              </span>
            </div>
          </div>

          <!-- Description -->
          <div class="prose dark:prose-invert max-w-none">
            <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
              {description}
            </p>
          </div>

          <!-- Tags -->
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <a 
                href={`/?tag=${tag}`}
                class="px-3 py-1.5 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg text-sm hover:bg-violet-100 dark:hover:bg-violet-900/30 hover:text-violet-700 dark:hover:text-violet-300 transition-colors"
              >
                #{tag}
              </a>
            ))}
          </div>

          <!-- Actions -->
          <div class="flex flex-wrap gap-3 pt-4 border-t border-gray-200 dark:border-gray-700">
            <button class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors text-sm font-medium">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
              </svg>
              Partager
            </button>
            
            <button class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors text-sm font-medium">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/>
              </svg>
              Télécharger
            </button>

            <button class="inline-flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors text-sm font-medium">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
              </svg>
              Sauvegarder
            </button>
          </div>
        </div>

        <!-- Contenu Markdown si présent -->
        {video.body && (
          <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6">
            <article class="prose dark:prose-invert max-w-none prose-headings:text-gray-900 dark:prose-headings:text-white prose-a:text-violet-600 dark:prose-a:text-violet-400">
                   <MdxContentEnhanced 
        content={video.body}
        enableCopy={true}
        enableAnchors={true}
        enableHighlight={true}
        client:load
      />

            </article>
          </div>
        )}
      </div>

      <!-- Sidebar : Vidéos similaires -->
      <div class="space-y-6">
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg p-6">
          <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
            Vidéos similaires
          </h2>
          
          <div class="space-y-4">
            {relatedVideos.length > 0 ? relatedVideos.map(relatedVideo => (
              <a 
                href={`/videos/${relatedVideo.id}`}
                class="group flex gap-3 p-2 -mx-2 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors"
              >
                <div class="relative w-40 aspect-video rounded-lg overflow-hidden flex-shrink-0 bg-gray-100 dark:bg-gray-700">
                  {relatedVideo.data.thumbnail ? (
                    <img 
                      src={relatedVideo.data.thumbnail} 
                      alt={relatedVideo.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-violet-500 to-indigo-600">
                      <svg class="w-8 h-8 text-white/80" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  )}
                  {relatedVideo.data.duration && (
                    <span class="absolute bottom-1 right-1 px-1.5 py-0.5 bg-black/75 text-white text-[10px] rounded">
                      {relatedVideo.data.duration >= 3600 
                        ? new Date(relatedVideo.data.duration * 1000).toISOString().substr(11, 8)
                        : new Date(relatedVideo.data.duration * 1000).toISOString().substr(14, 5)
                      }
                    </span>
                  )}
                </div>
                
                <div class="flex-1 min-w-0">
                  <h3 class="text-sm font-semibold text-gray-900 dark:text-white line-clamp-2 group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">
                    {relatedVideo.data.title}
                  </h3>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
                    {formatDate(relatedVideo.data.date)}
                  </p>
                  <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">
                    {relatedVideo.data.category}
                  </p>
                </div>
              </a>
            )) : (
              <p class="text-sm text-gray-500 dark:text-gray-400 text-center py-4">
                Aucune vidéo similaire trouvée
              </p>
            )}
          </div>
        </div>

        <!-- Statistiques -->
        <div class="bg-gradient-to-br from-violet-500 to-indigo-600 rounded-2xl shadow-lg p-6 text-white">
          <h2 class="text-lg font-bold mb-4">📊 Informations</h2>
          <div class="space-y-3">
            <div class="flex justify-between items-center text-sm">
              <span class="text-violet-100">Catégorie</span>
              <span class="font-medium">{categoryLabels[category]}</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-violet-100">Date</span>
              <span class="font-medium">{formatDate(date)}</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-violet-100">Durée</span>
              <span class="font-medium">{formatDuration(duration || 0)}</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-violet-100">Tags</span>
              <span class="font-medium">{tags.length}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DefaultLayout>