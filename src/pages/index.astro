---
import { getCollection } from 'astro:content';
import DefaultLayout from '../layouts/DefaultLayout.astro';
import VideoList from '../components/VideoList.vue';

const videos = await getCollection('videos');
const featuredVideos = videos.filter(v => v.data.featured);
const totalVideos = videos.length;
const totalCategories = [...new Set(videos.map(v => v.data.category))].length;
const totalTags = [...new Set(videos.flatMap(v => v.data.tags))].length;
---

<DefaultLayout 
  title="Vidéothèque | Collection de vidéos"
  description="Découvrez notre collection de vidéos organisées par catégories et tags"
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-violet-600 via-indigo-600 to-purple-700 p-8 md:p-12 mb-12">
    <!-- Décorations d'arrière-plan -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute -top-24 -right-24 w-96 h-96 bg-white rounded-full blur-3xl"></div>
      <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-white rounded-full blur-3xl"></div>
    </div>
    
    <div class="relative">
      <div class="flex flex-col lg:flex-row items-center gap-8">
        <div class="flex-1 text-center lg:text-left">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 tracking-tight">
            Explorez notre
            <span class="block mt-2 bg-gradient-to-r from-yellow-200 to-pink-200 bg-clip-text text-transparent">
              Vidéothèque
            </span>
          </h1>
          <p class="text-lg text-violet-100 mb-8 max-w-2xl mx-auto lg:mx-0">
            Découvrez, apprenez et inspirez-vous avec notre collection de vidéos soigneusement organisées. 
            Des tutoriels aux présentations, trouvez le contenu qui vous correspond.
          </p>
          
          <!-- Statistiques -->
          <div class="flex flex-wrap gap-6 justify-center lg:justify-start">
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-3 border border-white/20">
              <div class="text-3xl font-bold text-white">{totalVideos}</div>
              <div class="text-sm text-violet-200">Vidéos</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-3 border border-white/20">
              <div class="text-3xl font-bold text-white">{totalCategories}</div>
              <div class="text-sm text-violet-200">Catégories</div>
            </div>
            <div class="bg-white/10 backdrop-blur-sm rounded-2xl px-6 py-3 border border-white/20">
              <div class="text-3xl font-bold text-white">{totalTags}</div>
              <div class="text-sm text-violet-200">Tags</div>
            </div>
          </div>
        </div>
        
        <!-- Illustration -->
        <div class="flex-1 flex justify-center">
          <div class="relative">
            <div class="w-64 h-64 bg-white/10 backdrop-blur-sm rounded-full flex items-center justify-center border border-white/20 shadow-2xl">
              <svg class="w-32 h-32 text-white/90" fill="currentColor" viewBox="0 0 24 24">
                <path d="M3 22v-6l4-2 4 2v6H3zm14 0v-7l4-2 4 2v7h-8zm-7-8V7l4-2 4 2v7h-8z"/>
              </svg>
            </div>
            <!-- Cercles décoratifs -->
            <div class="absolute -top-4 -right-4 w-16 h-16 bg-yellow-400 rounded-full opacity-20 animate-ping"></div>
            <div class="absolute -bottom-4 -left-4 w-12 h-12 bg-pink-400 rounded-full opacity-20 animate-ping delay-500"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Vidéos en avant -->
  {featuredVideos.length > 0 && (
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-2 h-8 bg-gradient-to-b from-violet-600 to-indigo-600 rounded-full"></div>
        <h2 class="text-3xl font-bold bg-gradient-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">
          Vidéos en vedette
        </h2>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredVideos.slice(0, 3).map(video => (
			<a href={`/videos/${video.id}`} class="block group">
          <article class="group relative bg-white dark:bg-gray-800 rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-1">
            <div class="aspect-video bg-gray-100 dark:bg-gray-700 relative overflow-hidden">
              {video.data.thumbnail ? (
                <img 
                  src={video.data.thumbnail} 
                  alt={video.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-violet-500 to-indigo-600">
                  <svg class="w-16 h-16 text-white/80" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                </div>
              )}
              <div class="absolute top-3 right-3">
                <span class="px-3 py-1 text-xs font-semibold bg-yellow-400 text-yellow-900 rounded-full shadow-lg">
                  ⭐ En vedette
                </span>
              </div>
            </div>
            
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="px-2.5 py-1 text-xs font-medium bg-violet-100 text-violet-700 dark:bg-violet-900/50 dark:text-violet-300 rounded-full">
                  {video.data.category}
                </span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2 line-clamp-2">
                {video.data.title}
              </h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-4">
                {video.data.description}
              </p>
              <div class="flex flex-wrap gap-1">
                {video.data.tags.slice(0, 3).map(tag => (
                  <span class="px-2 py-0.5 text-xs bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400 rounded-md">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>
            <a href={`/videos/${video.id}`} class="absolute inset-0">
              <span class="sr-only">Voir {video.data.title}</span>
            </a>
          </article>
		  </a>
        ))}
      </div>
    </section>
  )}

  <!-- Toutes les vidéos -->
  <section>
    <div class="flex items-center gap-3 mb-8">
      <div class="w-2 h-8 bg-gradient-to-b from-violet-600 to-indigo-600 rounded-full"></div>
      <h2 class="text-3xl font-bold bg-gradient-to-r from-gray-900 to-gray-700 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">
        Toutes les vidéos
      </h2>
      <span class="text-sm text-gray-500 dark:text-gray-400 mt-2">
        ({totalVideos} vidéos)
      </span>
    </div>
    
    <VideoList videos={videos} client:load />
  </section>

  <!-- État vide -->
  {videos.length === 0 && (
    <div class="text-center py-20">
      <div class="w-24 h-24 mx-auto mb-6 bg-gray-100 dark:bg-gray-800 rounded-full flex items-center justify-center">
        <svg class="w-12 h-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
      </div>
      <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Aucune vidéo disponible</h3>
      <p class="text-gray-600 dark:text-gray-400 mb-6">
        Commencez par ajouter des vidéos via le panneau d'administration Decap CMS.
      </p>
      <a 
        href="/admin/" 
        class="inline-flex items-center gap-2 px-6 py-3 text-sm font-medium text-white bg-gradient-to-r from-violet-600 to-indigo-600 rounded-xl shadow-lg shadow-violet-500/25 hover:shadow-violet-500/40 hover:scale-105 transition-all duration-200"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Ajouter une vidéo
      </a>
    </div>
  )}
</DefaultLayout>